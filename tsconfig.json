{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "strict": true,
    "jsx": "preserve",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "sourceMap": true,
    "baseUrl": ".",

    /* 核心修改部分 */
    "allowJs": true,                    // 2. 允许编译器处理 .js 文件
    "checkJs": false,                   // 3. 不检查 .js 文件内部的错误
    "noImplicitAny": false,             // 4. 关闭隐式 any 报错
    "noUnusedLocals": false,            // 5. 允许定义但不使用的变量
    "noUnusedParameters": false,        // 6. 允许定义但不使用的参数
    
    "types": [
      "webpack-env"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "tests/**/*.ts",
    "tests/**/*.tsx"
, "src/icons/index.ts", "src/store/modules/user.js", "src/store/index.js", "src/router/index.js", "src/main.ts"  ],
  "exclude": [
    "node_modules"
  ]
}
